# set the node flag to private
#alt + p
#bspc node -g private

# === function keys ===

# rotate windows
F1
	bspc node @/ -R 90

# circulate windows
alt + F2
	bspc node @/ -C forward

# flip windows horizontal
alt + F3
	bspc node @/ -F horizontal

# flip windows vertical
F4
	bspc node @/ -F vertical

# alternate between the tiled and monocle layout
F5
	bspc desktop -l next

# balance windows
F6
	bspc node @/ -B

# Change window gap
{F7,F8}
	bspc config -d focused window_gap $((`bspc config -d focused window_gap` {+,-} 2 ))

# set the window state
{F9,F10,F11,F12}
	bspc node -t {floating,tiled,pseudo_tiled,fullscreen}

# === focus/swap ===

# focus the next/previous node
#alt + {Up,Down}
	bspc node -f {prev,next}.local.!above

# focus the next/previous desktop
#alt + {Left,Right}
	bspc desktop -f {prev,next}

alt + {Left,Down,Up,Right}
    bspc config pointer_follows_monitor true; \
    bspc config pointer_follows_focus true; \
    dir={west,south,north,east}; \
        if ! bspc node -f $dir; then \
    bspc monitor -f $dir; \
    fi; \
    bspc config pointer_follows_monitor false; \
    bspc config pointer_follows_focus false


alt + shift + {Left,Down,Up,Right}
    bspc config pointer_follows_focus true; \
    cur_win=$(bspc query -N -n); \
    cur_mon=$(bspc query -M -m); \
    dir={west,south,north,east}; \
    if ! bspc node -f $dir; then \
        bspc node -m $dir; \
        bspc monitor -f $dir; \
    else \
        new_mon=$(bspc query -M -m); \
        if [ $new_mon = $cur_mon ]; then \
            bspc node -s $cur_win; \
        else \
            bspc node $cur_win -m $new_mon; \
        fi; \
    bspc node -f $cur_win; \
    fi; \
    bspc config pointer_follows_focus false
